<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <ImageView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/ic_power_menu"
        android:contentDescription="@string/app_name"
        app:tint="?attr/colorPrimary"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setup_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/setup_desc_not_granted"
        android:textSize="16sp"
        android:gravity="center"
        android:textColor="?android:attr/textColorSecondary"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_grant_permission"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:textColor="?attr/colorOnPrimary"
        android:backgroundTint="?attr/colorPrimary"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:stateListAnimator="@null"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvHideIconDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/hide_icon_desc"
        android:textSize="14sp"
        android:gravity="center"
        android:visibility="gone"
        android:textColor="?android:attr/textColorSecondary"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnHideIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_hide_app_icon"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:visibility="gone"
        android:textColor="?attr/colorPrimary"
        android:backgroundTint="?android:attr/colorBackgroundFloating"
        style="?android:attr/borderlessButtonStyle"
        android:textAllCaps="false"
        android:textSize="16sp" />

</LinearLayout>
